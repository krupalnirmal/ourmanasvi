// OurManasvi — Database schema
// Provider: MySQL (TiDB Cloud Starter is MySQL-compatible, free tier)
// relationMode = "prisma" keeps referential integrity in the app layer,
// which is the recommended + safest setup for TiDB serverless.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model Baby {
  id            String   @id @default(cuid())
  name          String
  tagline       String?  @db.Text
  birthDate     DateTime
  firstBirthday DateTime?
  coverImage    String?
  profilePhoto  String? // avatar for the "Hello, I'm…" card
  storyAudio    String? // music for the "Watch our Journey" player
  bannerAudio   String? // music for the homepage banner slideshow
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  months Month[]
}

model Month {
  id          String   @id @default(cuid())
  babyId      String
  monthNumber Int // 0 = birth, 1..12 = each month
  title       String
  subtitle    String?
  description  String?  @db.Text
  coverImage  String?
  date        DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  baby       Baby        @relation(fields: [babyId], references: [id], onDelete: Cascade)
  gallery    Gallery[]
  videos     Video[]
  memories   Memory[]
  milestones Milestone[]

  @@unique([babyId, monthNumber])
  @@index([babyId])
}

model Gallery {
  id        String   @id @default(cuid())
  monthId   String
  imageUrl  String
  publicId  String // Cloudinary public_id, for deletion
  caption   String?
  sortOrder Int      @default(0)
  featured  Boolean  @default(false) // starred → shown on the homepage
  featuredRank Int? // 1 = best; drives the homepage banner order
  createdAt DateTime @default(now())

  month Month @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@index([monthId])
}

model Video {
  id         String   @id @default(cuid())
  monthId    String
  videoUrl   String
  publicId   String
  thumbnail  String?
  caption    String?
  slowMotion Boolean  @default(false)
  createdAt  DateTime @default(now())

  month Month @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@index([monthId])
}

model Memory {
  id        String   @id @default(cuid())
  monthId   String
  title     String
  content   String   @db.Text
  mood      String?
  date      DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  month Month @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@index([monthId])
}

model Milestone {
  id          String   @id @default(cuid())
  monthId     String
  title       String
  description String?  @db.Text
  icon        String?
  achievedAt  DateTime?
  createdAt   DateTime @default(now())

  month Month @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@index([monthId])
}

model Family {
  id        String   @id @default(cuid())
  name      String
  relation  String // e.g. "Mother", "Grandpa"
  photoUrl  String?
  publicId  String?
  message   String?  @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Place {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  date        DateTime?
  imageUrl    String?
  publicId    String?
  createdAt   DateTime @default(now())
}

model Festival {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  date        DateTime?
  imageUrl    String?
  publicId    String?
  createdAt   DateTime @default(now())

  media EventMedia[]
}

// Photos/videos belonging to an event (each event has its own gallery page).
model EventMedia {
  id         String   @id @default(cuid())
  festivalId String
  kind       String // "image" | "video"
  url        String
  publicId   String
  thumbnail  String?
  caption    String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  festival Festival @relation(fields: [festivalId], references: [id], onDelete: Cascade)

  @@index([festivalId])
}

// Hand-picked wide photos for the homepage hero banner (rank 1 shows first).
model BannerPhoto {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  rank      Int      @default(0)
  createdAt DateTime @default(now())
}

// The "Funny" page's media.
model FunMedia {
  id        String   @id @default(cuid())
  kind      String // "image" | "video"
  url       String
  publicId  String
  thumbnail String?
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}
